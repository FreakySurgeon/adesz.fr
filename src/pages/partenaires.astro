---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPage, getPostsByCategory, PAGES, CATEGORIES } from '../lib/wordpress';

const page = await getPage(PAGES.PARTENAIRES);
const partnerPosts = await getPostsByCategory(CATEGORIES.PARTENAIRES);
---

<BaseLayout title="Nos partenaires - ADESZ" description="Découvrez les partenaires de l'ADESZ qui soutiennent le développement de Zafaya.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href="/" class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Nos partenaires</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Nos partenaires
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        Ils nous accompagnent et soutiennent nos actions pour le d&eacute;veloppement de Zafaya.
      </p>
    </div>
  </div>

  <!-- WP Page Content -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div
        class="prose prose-lg max-w-none prose-headings:text-[#2D3436] prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-img:shadow-md"
        set:html={page.content.rendered}
      />
    </div>
  </section>

  <!-- Partner Posts -->
  {partnerPosts.length > 0 && (
    <section class="bg-[#F8F7F4] py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl sm:text-3xl font-bold text-[#2D3436] border-l-4 border-[#2D7A3A] pl-4 mb-10">
          Nos partenaires en d&eacute;tail
        </h2>
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {partnerPosts.map((post) => {
            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
            const cleanExcerpt = post.excerpt.rendered.replace(/<[^>]*>/g, '').slice(0, 150).trim() + '...';
            return (
              <article class="overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg">
                <div class="aspect-[16/10] overflow-hidden">
                  {featuredImage ? (
                    <img
                      src={featuredImage}
                      alt={post.title.rendered.replace(/<[^>]*>/g, '')}
                      class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-[#2D7A3A] to-[#1B5E27]">
                      <svg class="h-12 w-12 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-6">
                  <h3 class="text-lg font-semibold leading-snug text-[#2D3436]">
                    <Fragment set:html={post.title.rendered} />
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-[#2D3436]/70">
                    {cleanExcerpt}
                  </p>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
