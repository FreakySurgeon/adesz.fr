---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/utils';
---

<BaseLayout title="Merci ! - ADESZ" description="Merci pour votre don à l'ADESZ.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Merci</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Merci !
      </h1>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <!-- Green Checkmark Icon -->
      <div class="reveal flex h-20 w-20 mx-auto items-center justify-center rounded-full bg-[#2D7A3A]/10">
        <svg class="h-10 w-10 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="reveal reveal-delay-1 mt-8 font-display text-3xl sm:text-4xl font-bold text-[#2D3436]">
        Merci pour votre soutien !
      </h1>

      <!-- Paragraph -->
      <p class="reveal reveal-delay-2 mt-6 text-lg text-[#2D3436]/70 leading-relaxed max-w-2xl mx-auto">
        Votre contribution permettra de soutenir nos actions pour le d&eacute;veloppement de Zafaya. Chaque don compte et fait une r&eacute;elle diff&eacute;rence.
      </p>
    </div>
  </section>

  <!-- Fiscal Deductibility Card -->
  <section class="bg-white pb-12 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="reveal rounded-2xl bg-gradient-to-r from-[#2D7A3A] to-[#1B5E27] p-8 sm:p-10 text-white shadow-lg">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white/20">
            <svg class="h-6 w-6 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold">D&eacute;ductibilit&eacute; fiscale</h3>
            <p class="mt-3 leading-relaxed text-white/90">
              L'ADESZ est reconnue d'int&eacute;r&ecirc;t g&eacute;n&eacute;ral. Votre don est d&eacute;ductible &agrave;
              <strong class="text-[#F5C518]">66%</strong> de votre imp&ocirc;t sur le revenu (particuliers) ou
              <strong class="text-[#F5C518]">60%</strong> de l'imp&ocirc;t sur les soci&eacute;t&eacute;s (entreprises).
              Un re&ccedil;u fiscal vous sera envoy&eacute;.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Return Button -->
  <section class="bg-white pb-16 sm:pb-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <a
        href={url('/')}
        class="reveal inline-flex items-center justify-center rounded-lg bg-[#2D7A3A] px-8 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-[#1B5E27] hover:shadow-lg"
      >
        <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Retour &agrave; l'accueil
      </a>
    </div>
  </section>
</BaseLayout>
