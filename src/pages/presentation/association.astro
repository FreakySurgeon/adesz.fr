---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import DonationCTA from '../../components/DonationCTA.astro';
import { getPage, PAGES } from '../../lib/wordpress';
import { url } from '../../lib/utils';

const page = await getPage(PAGES.ASSOCIATION);

const siblingPages = [
  { label: 'Le Pays', href: url('/presentation/pays'), active: false },
  { label: 'Le Village', href: url('/presentation/village'), active: false },
  { label: "L'Association", href: url('/presentation/association'), active: true },
];
---

<BaseLayout title={`${page.title.rendered} - ADESZ`} description="Pr\u00e9sentation de l'association ADESZ">
  <PageHero
    title={page.title.rendered}
    subtitle="Notre histoire, notre mission, notre \u00e9quipe"
    image="/images/community.webp"
    imageAlt="Communaut\u00e9 ADESZ"
    breadcrumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Pr\u00e9sentation' },
      { label: "L'Association" },
    ]}
  />

  <!-- Sub-navigation -->
  <div class="border-b border-[#2D3436]/5 bg-white sticky top-16 z-30 lg:top-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-1 -mb-px" aria-label="Sous-navigation pr\u00e9sentation">
        {siblingPages.map((p) => (
          <a
            href={p.href}
            class={`whitespace-nowrap border-b-2 px-4 py-3 text-sm font-semibold transition-colors ${
              p.active
                ? 'border-[#2D7A3A] text-[#2D7A3A]'
                : 'border-transparent text-[#2D3436]/50 hover:border-[#2D3436]/20 hover:text-[#2D3436]'
            }`}
          >
            {p.label}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Content -->
  <section class="relative bg-warm-gradient py-16 sm:py-20">
    <div class="absolute inset-0 pattern-diamonds"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="reveal rounded-2xl bg-white p-8 shadow-lg sm:p-12">
        <div
          class="prose prose-lg max-w-none
            prose-headings:font-display prose-headings:text-[#2D3436]
            prose-h2:border-l-4 prose-h2:border-[#F5C518] prose-h2:pl-4 prose-h2:mt-12 prose-h2:first:mt-0
            prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline
            prose-img:rounded-xl prose-img:shadow-lg
            prose-strong:text-[#2D3436]
            prose-blockquote:border-[#2D7A3A] prose-blockquote:bg-[#2D7A3A]/5 prose-blockquote:rounded-r-lg prose-blockquote:py-1 prose-blockquote:pr-4"
          set:html={page.content.rendered}
        />
      </div>
    </div>
  </section>

  <DonationCTA />
</BaseLayout>
