---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPage, PAGES } from '../../lib/wordpress';

const page = await getPage(PAGES.ASSOCIATION);
---

<BaseLayout title={`${page.title.rendered} - ADESZ`} description="Presentation de l'association ADESZ">
  <!-- Hero Banner -->
  <div class="relative h-64 sm:h-80 md:h-96 overflow-hidden">
    <img
      src="/images/community.jpg"
      alt="Communaute ADESZ"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white text-center px-4" set:html={page.title.rendered} />
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="bg-[#F8F7F4]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <nav class="text-sm text-[#2D3436]/60">
        <a href="/" class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span>Pr&eacute;sentation</span>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">L'Association</span>
      </nav>
    </div>
  </div>

  <!-- Content -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none prose-headings:text-[#2D3436] prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline" set:html={page.content.rendered} />
    </div>
  </section>
</BaseLayout>
