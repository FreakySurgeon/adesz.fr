---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getPostsByCategory, CATEGORIES } from '../../lib/wordpress';

const realisations = await getPostsByCategory(CATEGORIES.REALISATIONS);
---

<BaseLayout title="Nos réalisations - ADESZ" description="Les projets réalisés par l'ADESZ pour le développement de Zafaya.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href="/" class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Nos réalisations</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Nos réalisations
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        Les projets réalisés par l'ADESZ pour le développement de Zafaya.
      </p>
    </div>
  </div>

  <!-- Réalisations -->
  {realisations.length > 0 && (
    <section class="bg-white py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {realisations.map((post) => {
            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
            return (
              <ProjectCard
                title={post.title.rendered}
                date={post.date}
                excerpt={post.excerpt.rendered}
                slug={post.slug}
                image={featuredImage}
                basePath="/realisations"
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Empty state -->
  {realisations.length === 0 && (
    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-lg text-[#2D3436]/70">Aucune réalisation disponible pour le moment.</p>
      </div>
    </section>
  )}
</BaseLayout>
