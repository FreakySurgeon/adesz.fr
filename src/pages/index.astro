---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImpactStats from '../components/ImpactStats.astro';
import DomaineCard from '../components/DomaineCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import DonationCTA from '../components/DonationCTA.astro';
import { getPosts, CATEGORIES } from '../lib/wordpress';

const latestPosts = await getPosts({ per_page: '3', orderby: 'date', order: 'desc' });

function getPostBasePath(categories: number[]): string {
  if (categories.includes(CATEGORIES.PROJETS_EN_COURS) || categories.includes(CATEGORIES.PROJETS_A_VENIR) || categories.includes(CATEGORIES.PROJETS)) return '/projets';
  if (categories.includes(CATEGORIES.REALISATIONS)) return '/realisations';
  return '/presse';
}

const domaines = [
  {
    title: '\u00c9ducation',
    description:
      'Soutenir la scolarisation des enfants de Zafaya en construisant des salles de classe, en fournissant du mat\u00e9riel scolaire et en formant les enseignants.',
    image: '/images/education.webp',
    link: '/domaines#education',
  },
  {
    title: 'Sant\u00e9',
    description:
      'Am\u00e9liorer l\u2019acc\u00e8s aux soins en r\u00e9novant le centre de sant\u00e9, en \u00e9quipant les structures m\u00e9dicales et en sensibilisant la population.',
    image: '/images/health.jpg',
    link: '/domaines#sante',
  },
  {
    title: 'D\u00e9veloppement agricole',
    description:
      'Favoriser l\u2019autonomie alimentaire en soutenant les coop\u00e9ratives agricoles, en d\u00e9veloppant l\u2019irrigation et en formant les agriculteurs.',
    image: '/images/agriculture-new.webp',
    link: '/domaines#agriculture',
  },
];
---

<BaseLayout title="ADESZ - Association pour le Développement, l'Entraide et la Solidarité du Village de Zafaya">
  <!-- Hero Section -->
  <Hero />

  <!-- Impact Stats -->
  <ImpactStats />

  <!-- Domaines d'action -->
  <section class="relative bg-warm-gradient py-20 sm:py-28">
    <div class="absolute inset-0 pattern-diamonds"></div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="reveal text-center">
        <div class="mb-4 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-[#F5C518]"></span>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-[#2D7A3A]">Notre mission</span>
          <span class="h-px w-8 bg-[#F5C518]"></span>
        </div>
        <h2 class="font-display text-3xl text-[#2D3436] sm:text-4xl lg:text-5xl">
          Nos domaines d'action
        </h2>
      </div>
      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {domaines.map((domaine, i) => (
          <div class={`reveal-delay-${i + 1}`}>
            <DomaineCard
              title={domaine.title}
              description={domaine.description}
              image={domaine.image}
              link={domaine.link}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Derni&egrave;res actualit&eacute;s -->
  <section class="relative bg-white py-20 sm:py-28">
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Section header -->
      <div class="reveal text-center">
        <div class="mb-4 flex items-center justify-center gap-3">
          <span class="h-px w-8 bg-[#F5C518]"></span>
          <span class="text-xs font-bold uppercase tracking-[0.25em] text-[#2D7A3A]">Actualit&eacute;s</span>
          <span class="h-px w-8 bg-[#F5C518]"></span>
        </div>
        <h2 class="font-display text-3xl text-[#2D3436] sm:text-4xl lg:text-5xl">
          Derni&egrave;res nouvelles
        </h2>
      </div>
      <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post, i) => {
          const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
          return (
            <div class={`reveal-delay-${i + 1}`}>
              <ArticleCard
                title={post.title.rendered}
                date={post.date}
                excerpt={post.excerpt.rendered}
                slug={post.slug}
                image={featuredImage}
                basePath={getPostBasePath(post.categories)}
              />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Donation CTA -->
  <DonationCTA />
</BaseLayout>
