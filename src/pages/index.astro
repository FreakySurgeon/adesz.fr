---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ImpactStats from '../components/ImpactStats.astro';
import DomaineCard from '../components/DomaineCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import DonationCTA from '../components/DonationCTA.astro';
import { getPosts } from '../lib/wordpress';

const latestPosts = await getPosts({ per_page: '3', orderby: 'date', order: 'desc' });

const domaines = [
  {
    title: '\u00c9ducation',
    description:
      'Soutenir la scolarisation des enfants de Zafaya en construisant des salles de classe, en fournissant du mat\u00e9riel scolaire et en formant les enseignants.',
    image: '/images/education.jpg',
    link: '/domaines#education',
  },
  {
    title: 'Sant\u00e9',
    description:
      'Am\u00e9liorer l\u2019acc\u00e8s aux soins en r\u00e9novant le centre de sant\u00e9, en \u00e9quipant les structures m\u00e9dicales et en sensibilisant la population.',
    image: '/images/Centresante.jpg',
    link: '/domaines#sante',
  },
  {
    title: 'D\u00e9veloppement agricole',
    description:
      'Favoriser l\u2019autonomie alimentaire en soutenant les coop\u00e9ratives agricoles, en d\u00e9veloppant l\u2019irrigation et en formant les agriculteurs.',
    image: '/images/agriculture.jpg',
    link: '/domaines#agriculture',
  },
];
---

<BaseLayout title="ADESZ - Association pour le D\u00e9veloppement \u00c9conomique et Social de Zafaya">
  <!-- Hero Section -->
  <Hero />

  <!-- Impact Stats -->
  <ImpactStats />

  <!-- Domaines d'action -->
  <section class="bg-[#F8F7F4] py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold text-[#2D3436] sm:text-4xl">
        Nos domaines d'action
      </h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {domaines.map((domaine) => (
          <DomaineCard
            title={domaine.title}
            description={domaine.description}
            image={domaine.image}
            link={domaine.link}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Dernières actualités -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold text-[#2D3436] sm:text-4xl">
        Derni&egrave;res actualit&eacute;s
      </h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => {
          const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
          return (
            <ArticleCard
              title={post.title.rendered}
              date={post.date}
              excerpt={post.excerpt.rendered}
              slug={post.slug}
              image={featuredImage}
            />
          );
        })}
      </div>
    </div>
  </section>

  <!-- Donation CTA -->
  <DonationCTA />
</BaseLayout>
