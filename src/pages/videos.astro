---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/utils';
---

<BaseLayout title="Zafaya en vidéo - ADESZ" description="Découvrez Zafaya et les actions de l'ADESZ en vidéo.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Vid&eacute;os</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Zafaya en vid&eacute;o
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        D&eacute;couvrez le village de Zafaya et les actions de l'ADESZ &agrave; travers nos vid&eacute;os.
      </p>
    </div>
  </div>

  <!-- Videos Section -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <!-- Empty state -->
      <div class="text-center py-12">
        <div class="flex h-20 w-20 mx-auto items-center justify-center rounded-full bg-[#2D7A3A]/10 mb-6">
          <svg class="h-10 w-10 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-[#2D3436]">Vid&eacute;os &agrave; venir</h2>
        <p class="mt-4 text-lg text-[#2D3436]/70 max-w-xl mx-auto">
          Nous pr&eacute;parons des vid&eacute;os pour vous faire d&eacute;couvrir Zafaya, nos projets et l'impact de vos dons sur le terrain. Revenez bient&ocirc;t !
        </p>
      </div>

      <!-- Placeholder grid for future videos -->
      <div class="mt-8 grid gap-8 sm:grid-cols-2">
        <!-- Placeholder 1 -->
        <div class="group overflow-hidden rounded-xl bg-[#F8F7F4] shadow-md">
          <div class="relative aspect-video flex items-center justify-center bg-gradient-to-br from-[#2D7A3A]/10 to-[#1B5E27]/10">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/80 shadow-lg">
              <svg class="h-8 w-8 text-[#2D7A3A] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-[#2D3436]">D&eacute;couverte de Zafaya</h3>
            <p class="mt-1 text-sm text-[#2D3436]/60">Prochainement disponible</p>
          </div>
        </div>

        <!-- Placeholder 2 -->
        <div class="group overflow-hidden rounded-xl bg-[#F8F7F4] shadow-md">
          <div class="relative aspect-video flex items-center justify-center bg-gradient-to-br from-[#F5C518]/10 to-[#2D7A3A]/10">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/80 shadow-lg">
              <svg class="h-8 w-8 text-[#2D7A3A] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-[#2D3436]">Nos projets en action</h3>
            <p class="mt-1 text-sm text-[#2D3436]/60">Prochainement disponible</p>
          </div>
        </div>

        <!-- Placeholder 3 -->
        <div class="group overflow-hidden rounded-xl bg-[#F8F7F4] shadow-md">
          <div class="relative aspect-video flex items-center justify-center bg-gradient-to-br from-[#1B5E27]/10 to-[#F5C518]/10">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/80 shadow-lg">
              <svg class="h-8 w-8 text-[#2D7A3A] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-[#2D3436]">T&eacute;moignages</h3>
            <p class="mt-1 text-sm text-[#2D3436]/60">Prochainement disponible</p>
          </div>
        </div>

        <!-- Placeholder 4 -->
        <div class="group overflow-hidden rounded-xl bg-[#F8F7F4] shadow-md">
          <div class="relative aspect-video flex items-center justify-center bg-gradient-to-br from-[#2D7A3A]/10 to-[#F5C518]/10">
            <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/80 shadow-lg">
              <svg class="h-8 w-8 text-[#2D7A3A] ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-[#2D3436]">&Eacute;v&eacute;nements ADESZ</h3>
            <p class="mt-1 text-sm text-[#2D3436]/60">Prochainement disponible</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-[#2D3436]">
        En attendant nos vid&eacute;os...
      </h2>
      <p class="mt-4 text-lg text-[#2D3436]/70">
        D&eacute;couvrez nos projets et r&eacute;alisations pour le d&eacute;veloppement de Zafaya.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a
          href={url('/projets')}
          class="inline-flex items-center justify-center rounded-lg bg-[#2D7A3A] px-6 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-[#1B5E27] hover:shadow-lg"
        >
          Voir nos projets
        </a>
        <a
          href={url('/presse')}
          class="inline-flex items-center justify-center rounded-lg border-2 border-[#2D7A3A] bg-white px-6 py-3 text-sm font-semibold text-[#2D7A3A] shadow-md transition-all hover:bg-[#2D7A3A] hover:text-white hover:shadow-lg"
        >
          Articles de presse
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
