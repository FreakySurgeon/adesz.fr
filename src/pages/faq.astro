---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/utils';

const faqs = [
  {
    question: "Comment faire un don ?",
    answer: `Vous pouvez faire un don en ligne via notre page <a href='${url('/adherer')}' class='text-[#2D7A3A] underline hover:text-[#1B5E27]'>Adhérer / Faire un don</a>, par virement bancaire (IBAN FR76 3000 3015 0900 0372 6041 709), ou par chèque à l'ordre d'ADESZ.`
  },
  {
    question: "Comment adhérer à l'association ?",
    answer: `L'adhésion annuelle est de 15€. Rendez-vous sur notre <a href='${url('/adherer')}' class='text-[#2D7A3A] underline hover:text-[#1B5E27]'>page d'adhésion</a> pour adhérer en ligne, ou envoyez un chèque à notre adresse.`
  },
  {
    question: "Les dons sont-ils déductibles des impôts ?",
    answer: "Oui ! L'ADESZ est reconnue d'intérêt général. Vos dons sont déductibles à 66% de votre impôt sur le revenu (particuliers) ou 60% de l'impôt sur les sociétés (entreprises). Un reçu fiscal vous sera adressé."
  },
  {
    question: "Qui est l'ADESZ ?",
    answer: "L'Association pour le Développement Économique et Social de Zafaya (ADESZ) est une association loi 1901 basée à Antibes, œuvrant pour le développement du village de Zafaya au Tchad dans les domaines de l'éducation, la santé et l'agriculture."
  },
  {
    question: "Où se trouve Zafaya ?",
    answer: "Zafaya est un village situé dans la région du Batha, au centre du Tchad. Le village et ses environs comptent environ 10 000 habitants."
  },
  {
    question: "Comment suivre l'avancement des projets ?",
    answer: `Suivez notre actualité dans la rubrique <a href='${url('/presse')}' class='text-[#2D7A3A] underline hover:text-[#1B5E27]'>Articles de presse</a> et sur nos réseaux sociaux (Facebook). Vous pouvez également <a href='${url('/contact')}' class='text-[#2D7A3A] underline hover:text-[#1B5E27]'>nous contacter</a> directement.`
  },
];
---

<BaseLayout title="Foire aux questions - ADESZ" description="Retrouvez les réponses aux questions les plus fréquentes sur l'ADESZ et ses actions à Zafaya.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">FAQ</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Foire aux questions
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        Retrouvez les r&eacute;ponses aux questions les plus fr&eacute;quentes.
      </p>
    </div>
  </div>

  <!-- FAQ Accordion -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="divide-y divide-[#2D3436]/10">
        {faqs.map((faq, index) => (
          <details class="group" open={index === 0}>
            <summary class="flex cursor-pointer items-center justify-between py-6 text-left">
              <span class="text-lg font-semibold text-[#2D7A3A] group-open:text-[#1B5E27] pr-4">
                {faq.question}
              </span>
              <span class="shrink-0 ml-2">
                <svg
                  class="h-5 w-5 text-[#2D7A3A] transition-transform duration-200 group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </span>
            </summary>
            <div class="pb-6 pl-0 pr-8">
              <p class="leading-relaxed text-[#2D3436]/80" set:html={faq.answer} />
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-[#2D3436]">
        Vous n'avez pas trouv&eacute; votre r&eacute;ponse ?
      </h2>
      <p class="mt-4 text-lg text-[#2D3436]/70">
        N'h&eacute;sitez pas &agrave; nous contacter directement, nous vous r&eacute;pondrons dans les plus brefs d&eacute;lais.
      </p>
      <a
        href={url('/contact')}
        class="mt-6 inline-flex items-center justify-center rounded-lg bg-[#2D7A3A] px-8 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-[#1B5E27] hover:shadow-lg"
      >
        Nous contacter
      </a>
    </div>
  </section>
</BaseLayout>
