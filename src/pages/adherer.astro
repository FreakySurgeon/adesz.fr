---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPage, PAGES } from '../lib/wordpress';
import { url } from '../lib/utils';

const page = await getPage(PAGES.ADHERER);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Adhérer / Faire un don - ADESZ" description="Soutenez l'ADESZ en faisant un don ou en devenant membre. Vos dons sont déductibles des impôts.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Adh&eacute;rer / Faire un don</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Adh&eacute;rer / Faire un don
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        Soutenez nos actions pour le d&eacute;veloppement de Zafaya. Chaque contribution compte.
      </p>
    </div>
  </div>

  <!-- Interactive Payment Form -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <div id="payment-form" data-base={base} class="reveal mt-4 rounded-2xl border border-[#2D3436]/10 bg-white shadow-lg">

        <!-- Tab Bar -->
        <div class="flex border-b border-[#2D3436]/10" role="tablist">
          <button
            type="button"
            role="tab"
            aria-selected="true"
            data-tab="don"
            class="tab-btn flex-1 px-4 py-4 text-sm font-semibold transition-all bg-[#2D7A3A] text-white"
          >
            Faire un don
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab="adhesion"
            class="tab-btn flex-1 px-4 py-4 text-sm font-semibold transition-all bg-[#F8F7F4] text-[#2D3436] hover:bg-[#F8F7F4]/80"
          >
            Adh&eacute;rer (15&euro;)
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-tab="combo"
            class="tab-btn relative flex-1 px-4 py-4 text-sm font-semibold transition-all bg-[#F8F7F4] text-[#2D3436] hover:bg-[#F8F7F4]/80"
          >
            Don + Adh&eacute;sion
            <span class="absolute -top-2 right-2 rounded-full bg-[#F5C518] px-2 py-0.5 text-[10px] font-bold text-[#2D3436] leading-tight shadow-sm">
              Recommand&eacute;
            </span>
          </button>
        </div>

        <!-- Form Body -->
        <div class="p-6 sm:p-8">

          <!-- Amount Selector (visible for don + combo, hidden for adhesion) -->
          <div id="amount-section">
            <label class="block text-sm font-semibold text-[#2D3436] mb-3">
              Montant de votre don
            </label>

            <!-- Preset Amounts -->
            <div class="grid grid-cols-4 gap-3 mb-4">
              <button
                type="button"
                data-amount="10"
                class="amount-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#F5C518]/50 hover:shadow-md"
              >
                10&euro;
              </button>
              <button
                type="button"
                data-amount="25"
                class="amount-btn rounded-xl border-2 border-[#F5C518] bg-[#F5C518] px-4 py-3 text-sm font-semibold text-[#2D3436] shadow-md ring-2 ring-[#F5C518]/30 transition-all"
              >
                25&euro;
              </button>
              <button
                type="button"
                data-amount="50"
                class="amount-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#F5C518]/50 hover:shadow-md"
              >
                50&euro;
              </button>
              <button
                type="button"
                data-amount="100"
                class="amount-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#F5C518]/50 hover:shadow-md"
              >
                100&euro;
              </button>
            </div>

            <!-- Custom Amount -->
            <div class="relative">
              <input
                type="number"
                id="custom-amount"
                min="1"
                placeholder="Montant libre"
                class="w-full rounded-xl border-2 border-[#2D3436]/15 bg-[#F8F7F4] px-4 py-3 text-sm text-[#2D3436] placeholder-[#2D3436]/40 transition-all focus:border-[#2D7A3A] focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#2D7A3A]/20"
              />
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm font-medium text-[#2D3436]/50">&euro;</span>
            </div>
          </div>

          <!-- Frequency Selector (visible for don + combo, hidden for adhesion) -->
          <div id="frequency-section" class="mt-6">
            <label class="block text-sm font-semibold text-[#2D3436] mb-3">
              Fr&eacute;quence
            </label>
            <div class="grid grid-cols-3 gap-3">
              <button
                type="button"
                data-frequency="one_time"
                class="freq-btn rounded-xl border-2 border-[#2D7A3A] bg-white px-4 py-3 text-sm font-semibold text-[#2D7A3A] transition-all"
              >
                Ponctuel
              </button>
              <button
                type="button"
                data-frequency="monthly"
                class="freq-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#2D7A3A]/30"
              >
                Mensuel
              </button>
              <button
                type="button"
                data-frequency="yearly"
                class="freq-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#2D7A3A]/30"
              >
                Annuel
              </button>
            </div>

            <!-- Combo Info Note -->
            <p id="combo-note" class="mt-3 text-xs text-[#2D3436]/60 hidden">
              <svg class="inline-block h-4 w-4 mr-1 -mt-0.5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
              </svg>
              L'adh&eacute;sion est renouvel&eacute;e annuellement.
            </p>
          </div>

          <!-- Summary + Submit -->
          <div class="mt-8 pt-6 border-t border-[#2D3436]/10">
            <!-- Summary Text -->
            <p id="summary-text" class="text-center text-sm font-medium text-[#2D3436]/70 mb-4">
              Don de 25&euro; (ponctuel)
            </p>

            <!-- Error Message -->
            <p id="error-message" class="text-center text-sm text-red-600 mb-4 hidden"></p>

            <!-- Submit Button -->
            <button
              type="button"
              id="submit-btn"
              class="w-full rounded-xl bg-[#2D7A3A] px-8 py-4 text-base font-semibold text-white shadow-lg transition-all hover:bg-[#1B5E27] hover:shadow-xl disabled:cursor-not-allowed disabled:bg-[#2D3436]/30 disabled:shadow-none"
            >
              <span id="btn-text" class="inline-flex items-center justify-center gap-2">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v10.5a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
                Payer par carte
              </span>
              <span id="btn-loading" style="display:none" class="inline-flex items-center justify-center gap-2">
                <svg class="h-5 w-5 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Redirection&hellip;
              </span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Autres moyens de paiement -->
  <section class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-[#2D3436] border-l-4 border-[#2D7A3A] pl-4 mb-8">
        Autres moyens de paiement
      </h2>
      <div class="grid gap-6 sm:grid-cols-2">
        <!-- Virement bancaire -->
        <div class="rounded-xl border border-[#2D3436]/10 bg-white p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#2D7A3A]/10">
              <svg class="h-5 w-5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#2D3436]">Virement bancaire</h3>
          </div>
          <p class="text-sm text-[#2D3436]/70 mb-2">IBAN :</p>
          <p class="font-mono text-sm font-medium text-[#2D3436] bg-[#F8F7F4] rounded-lg px-4 py-2 border border-[#2D3436]/10">
            FR76 3000 3015 0900 0372 6041 709
          </p>
        </div>

        <!-- Chèque -->
        <div class="rounded-xl border border-[#2D3436]/10 bg-white p-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[#2D7A3A]/10">
              <svg class="h-5 w-5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#2D3436]">Ch&egrave;que</h3>
          </div>
          <p class="text-sm text-[#2D3436]/70">
            &Agrave; l'ordre d'<strong>ADESZ</strong>
          </p>
          <p class="mt-2 text-sm text-[#2D3436]/70">
            491 Bd Pierre Delmas<br />
            06600 Antibes
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Déductibilité fiscale -->
  <section class="bg-[#F8F7F4] pb-12 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-r from-[#2D7A3A] to-[#1B5E27] p-8 sm:p-10 text-white shadow-lg">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white/20">
            <svg class="h-6 w-6 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-bold">D&eacute;ductibilit&eacute; fiscale</h3>
            <p class="mt-3 leading-relaxed text-white/90">
              L'ADESZ est reconnue d'int&eacute;r&ecirc;t g&eacute;n&eacute;ral. Votre don est d&eacute;ductible &agrave;
              <strong class="text-[#F5C518]">66%</strong> de votre imp&ocirc;t sur le revenu (particuliers) ou
              <strong class="text-[#F5C518]">60%</strong> de l'imp&ocirc;t sur les soci&eacute;t&eacute;s (entreprises).
              Un re&ccedil;u fiscal vous sera envoy&eacute;.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WP Page Content (if any additional content exists) -->
  {page.content.rendered && page.content.rendered.trim() !== '' && (
    <section class="bg-[#F8F7F4] py-12 sm:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div
          class="prose prose-lg max-w-none prose-headings:text-[#2D3436] prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline"
          set:html={page.content.rendered}
        />
      </div>
    </section>
  )}
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- State ---
    let activeTab = 'don';
    let selectedAmount = 25;
    let customAmount = '';
    let frequency = 'one_time';
    let isLoading = false;

    // --- DOM refs ---
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const amountSection = document.getElementById('amount-section')!;
    const frequencySection = document.getElementById('frequency-section')!;
    const amountBtns = document.querySelectorAll<HTMLButtonElement>('.amount-btn');
    const customInput = document.getElementById('custom-amount') as HTMLInputElement;
    const freqBtns = document.querySelectorAll<HTMLButtonElement>('.freq-btn');
    const comboNote = document.getElementById('combo-note')!;
    const summaryText = document.getElementById('summary-text')!;
    const errorMessage = document.getElementById('error-message')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text')!;
    const btnLoading = document.getElementById('btn-loading')!;

    const ADHESION_PRICE = 15;

    // --- Helpers ---
    function frequencyLabel(freq: string): string {
      if (freq === 'monthly') return 'mensuel';
      if (freq === 'yearly') return 'annuel';
      return 'ponctuel'; // one_time
    }

    function getEffectiveAmount(): number {
      if (customAmount !== '' && Number(customAmount) >= 1) {
        return Number(customAmount);
      }
      return selectedAmount;
    }

    function isAmountValid(): boolean {
      if (activeTab === 'adhesion') return true;
      const amt = getEffectiveAmount();
      return amt >= 1;
    }

    // --- Update UI ---
    function updateTabs() {
      tabBtns.forEach((btn) => {
        const tab = btn.dataset.tab!;
        if (tab === activeTab) {
          btn.classList.remove('bg-[#F8F7F4]', 'text-[#2D3436]', 'hover:bg-[#F8F7F4]/80');
          btn.classList.add('bg-[#2D7A3A]', 'text-white');
          btn.setAttribute('aria-selected', 'true');
        } else {
          btn.classList.remove('bg-[#2D7A3A]', 'text-white');
          btn.classList.add('bg-[#F8F7F4]', 'text-[#2D3436]', 'hover:bg-[#F8F7F4]/80');
          btn.setAttribute('aria-selected', 'false');
        }
      });
    }

    function updateVisibility() {
      const showDonFields = activeTab === 'don' || activeTab === 'combo';
      amountSection.style.display = showDonFields ? '' : 'none';
      frequencySection.style.display = showDonFields ? '' : 'none';
      comboNote.classList.toggle('hidden', activeTab !== 'combo');
    }

    function updateAmountButtons() {
      amountBtns.forEach((btn) => {
        const amt = Number(btn.dataset.amount);
        const isSelected = customAmount === '' && amt === selectedAmount;
        if (isSelected) {
          btn.className = 'amount-btn rounded-xl border-2 border-[#F5C518] bg-[#F5C518] px-4 py-3 text-sm font-semibold text-[#2D3436] shadow-md ring-2 ring-[#F5C518]/30 transition-all';
        } else {
          btn.className = 'amount-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#F5C518]/50 hover:shadow-md';
        }
      });
    }

    function updateFrequencyButtons() {
      freqBtns.forEach((btn) => {
        const freq = btn.dataset.frequency!;
        if (freq === frequency) {
          btn.className = 'freq-btn rounded-xl border-2 border-[#2D7A3A] bg-white px-4 py-3 text-sm font-semibold text-[#2D7A3A] transition-all';
        } else {
          btn.className = 'freq-btn rounded-xl border-2 border-[#2D3436]/15 bg-white px-4 py-3 text-sm font-semibold text-[#2D3436] transition-all hover:border-[#2D7A3A]/30';
        }
      });
    }

    function updateSummary() {
      const amt = getEffectiveAmount();
      const freqText = frequencyLabel(frequency);

      if (activeTab === 'don') {
        summaryText.textContent = `Don de ${amt}\u202F\u20AC (${freqText})`;
      } else if (activeTab === 'adhesion') {
        summaryText.textContent = `Adh\u00E9sion : ${ADHESION_PRICE}\u202F\u20AC`;
      } else {
        summaryText.textContent = `Adh\u00E9sion (${ADHESION_PRICE}\u202F\u20AC) + Don de ${amt}\u202F\u20AC (${freqText})`;
      }
    }

    function updateSubmitButton() {
      const valid = isAmountValid();
      submitBtn.disabled = !valid || isLoading;
    }

    function updateAll() {
      updateTabs();
      updateVisibility();
      updateAmountButtons();
      updateFrequencyButtons();
      updateSummary();
      updateSubmitButton();
    }

    function showError(msg: string) {
      errorMessage.textContent = msg;
      errorMessage.classList.remove('hidden');
    }

    function hideError() {
      errorMessage.textContent = '';
      errorMessage.classList.add('hidden');
    }

    function setLoading(loading: boolean) {
      isLoading = loading;
      submitBtn.disabled = loading;
      btnText.style.display = loading ? 'none' : 'inline-flex';
      btnLoading.style.display = loading ? 'inline-flex' : 'none';
    }

    // --- Event Listeners ---

    // Tab clicks
    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeTab = btn.dataset.tab!;
        hideError();
        updateAll();
      });
    });

    // Preset amount clicks
    amountBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedAmount = Number(btn.dataset.amount);
        customAmount = '';
        customInput.value = '';
        hideError();
        updateAll();
      });
    });

    // Custom amount input
    customInput.addEventListener('input', () => {
      customAmount = customInput.value;
      hideError();
      updateAll();
    });

    // Frequency clicks
    freqBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        frequency = btn.dataset.frequency!;
        hideError();
        updateAll();
      });
    });

    // Submit
    submitBtn.addEventListener('click', async () => {
      if (!isAmountValid() || isLoading) return;

      hideError();
      setLoading(true);

      try {
        // PHP backend handles adhesion amount (1500 cents) internally.
        // We only send the donation amount for don/combo, or adhesion amount for adhesion.
        const amountCents = activeTab === 'adhesion'
          ? ADHESION_PRICE * 100
          : getEffectiveAmount() * 100;

        const basePath = document.getElementById('payment-form')?.dataset.base || '';
        const response = await fetch(basePath + '/api/create-checkout.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            amount: amountCents,
            frequency: activeTab === 'adhesion' ? 'one_time' : frequency,
            type: activeTab,
          }),
        });

        const data = await response.json();

        if (data.url) {
          window.location.href = data.url;
        } else {
          showError(data.error || 'Une erreur est survenue. Veuillez r\u00E9essayer.');
          setLoading(false);
        }
      } catch (_err) {
        showError('Impossible de contacter le serveur. V\u00E9rifiez votre connexion.');
        setLoading(false);
      }
    });

    // --- Initial render ---
    updateAll();
  });
</script>
