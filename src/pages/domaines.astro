---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPage, PAGES } from '../lib/wordpress';

const sante = await getPage(PAGES.SANTE);
const education = await getPage(PAGES.EDUCATION);
const agriculture = await getPage(PAGES.AGRICULTURE);
const developpement = await getPage(PAGES.DEVELOPPEMENT);
const urgences = await getPage(PAGES.URGENCES);

const domaines = [
  { data: sante, id: 'sante', image: '/images/Centresante.jpg', alt: 'Centre de sante a Zafaya' },
  { data: education, id: 'education', image: '/images/education.jpg', alt: 'Education a Zafaya' },
  { data: agriculture, id: 'agriculture', image: '/images/agriculture.jpg', alt: 'Agriculture a Zafaya' },
  { data: developpement, id: 'developpement', image: '/images/Image4.jpg', alt: 'Developpement a Zafaya' },
  { data: urgences, id: 'urgences', image: '/images/hero-africa.jpg', alt: 'Aide d urgence' },
];
---

<BaseLayout title="Nos domaines d'action - ADESZ" description="Decouvrez les domaines d'action de l'ADESZ : sante, education, agriculture, developpement et urgences.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href="/" class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Nos domaines d'action</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Nos domaines d'action
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        L'ADESZ intervient dans cinq domaines cl&eacute;s pour am&eacute;liorer les conditions de vie &agrave; Zafaya.
      </p>
    </div>
  </div>

  <!-- Domain Sections -->
  {domaines.map((domaine, index) => {
    const isEven = index % 2 === 0;
    const bgColor = isEven ? 'bg-white' : 'bg-[#F8F7F4]';
    return (
      <section id={domaine.id} class={`${bgColor} py-12 sm:py-16 scroll-mt-20`}>
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class={`flex flex-col ${isEven ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 lg:gap-12 items-start`}>
            <!-- Image -->
            <div class="w-full lg:w-2/5 shrink-0">
              <div class="relative overflow-hidden rounded-xl shadow-lg aspect-[4/3]">
                <img
                  src={domaine.image}
                  alt={domaine.alt}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>

            <!-- Content -->
            <div class="w-full lg:w-3/5">
              <h2 class="text-2xl sm:text-3xl font-bold text-[#2D3436] mb-6 border-l-4 border-[#2D7A3A] pl-4" set:html={domaine.data.title.rendered} />
              <div class="prose prose-lg max-w-none prose-headings:text-[#2D3436] prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline" set:html={domaine.data.content.rendered} />
            </div>
          </div>
        </div>
      </section>
    );
  })}
</BaseLayout>
