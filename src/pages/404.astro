---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/utils';
---

<BaseLayout title="Page introuvable - ADESZ" description="La page que vous recherchez n'existe pas ou a été déplacée.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Page introuvable</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Page introuvable
      </h1>
    </div>
  </div>

  <!-- Main Content -->
  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <!-- Icon -->
      <div class="reveal flex h-24 w-24 mx-auto items-center justify-center rounded-full bg-[#F5C518]/15">
        <svg class="h-12 w-12 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0 0 12.016 15a4.486 4.486 0 0 0-3.198 1.318M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
        </svg>
      </div>

      <!-- Error Code -->
      <p class="reveal reveal-delay-1 mt-6 text-6xl sm:text-7xl font-bold text-[#2D7A3A]/20">
        404
      </p>

      <!-- Message -->
      <h2 class="reveal reveal-delay-1 mt-4 font-display text-2xl sm:text-3xl font-bold text-[#2D3436]">
        Oups, cette page n'existe pas
      </h2>
      <p class="reveal reveal-delay-2 mt-4 text-lg text-[#2D3436]/70 leading-relaxed max-w-xl mx-auto">
        La page que vous recherchez a peut-&ecirc;tre &eacute;t&eacute; d&eacute;plac&eacute;e ou n'existe plus. Pas d'inqui&eacute;tude, vous pouvez retrouver votre chemin !
      </p>

      <!-- Buttons -->
      <div class="reveal reveal-delay-3 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={url('/')}
          class="inline-flex items-center justify-center rounded-lg bg-[#2D7A3A] px-8 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-[#1B5E27] hover:shadow-lg"
        >
          <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
          Retour &agrave; l'accueil
        </a>
        <a
          href={url('/contact')}
          class="inline-flex items-center justify-center rounded-lg border-2 border-[#2D7A3A] px-8 py-3 text-sm font-semibold text-[#2D7A3A] transition-all hover:bg-[#2D7A3A] hover:text-white"
        >
          Nous contacter
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
