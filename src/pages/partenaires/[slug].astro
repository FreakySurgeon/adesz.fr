---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPostsByCategory, CATEGORIES } from '../../lib/wordpress';
import type { WPPost } from '../../lib/wordpress';
import { url } from '../../lib/utils';

export async function getStaticPaths() {
  const partners = await getPostsByCategory(CATEGORIES.PARTENAIRES);
  return partners.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props as { post: WPPost };

const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const altText = post._embedded?.['wp:featuredmedia']?.[0]?.alt_text || post.title.rendered.replace(/<[^>]*>/g, '');
---

<BaseLayout title={`${post.title.rendered.replace(/<[^>]*>/g, '')} - ADESZ`}>
  <div class="bg-[#F8F7F4] py-10 sm:py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href={url('/')} class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <a href={url('/partenaires')} class="hover:text-[#2D7A3A] transition-colors">Nos partenaires</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium" set:html={post.title.rendered} />
      </nav>
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#2D3436]" set:html={post.title.rendered} />
    </div>
  </div>

  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      {featuredImage && (
        <div class="mb-10 overflow-hidden rounded-xl shadow-lg">
          <img
            src={featuredImage}
            alt={altText}
            class="h-auto w-full object-cover"
          />
        </div>
      )}
      <div class="prose prose-lg max-w-none prose-headings:text-[#2D3436] prose-a:text-[#2D7A3A] prose-a:no-underline hover:prose-a:underline prose-img:rounded-lg" set:html={post.content.rendered} />

      <div class="mt-12 border-t border-gray-200 pt-8">
        <a
          href={url('/partenaires')}
          class="inline-flex items-center text-sm font-medium text-[#2D7A3A] transition-colors hover:text-[#1B5E27]"
        >
          <span class="mr-1">&larr;</span>
          Retour aux partenaires
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
