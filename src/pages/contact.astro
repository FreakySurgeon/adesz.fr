---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nous contacter - ADESZ" description="Contactez l'ADESZ pour toute question ou demande d'information sur nos actions à Zafaya.">
  <!-- Page Header -->
  <div class="bg-[#F8F7F4] py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-[#2D3436]/60">
        <a href="/" class="hover:text-[#2D7A3A] transition-colors">Accueil</a>
        <span class="mx-2">&gt;</span>
        <span class="text-[#2D7A3A] font-medium">Contact</span>
      </nav>
      <h1 class="text-center text-3xl sm:text-4xl md:text-5xl font-bold text-[#2D3436]">
        Nous contacter
      </h1>
      <p class="mt-4 text-center text-lg text-[#2D3436]/70 max-w-2xl mx-auto">
        Une question, une suggestion ou envie de nous rejoindre ? N'h&eacute;sitez pas &agrave; nous &eacute;crire.
      </p>
    </div>
  </div>

  <!-- Contact Content -->
  <section class="bg-white py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <!-- Contact Form (left, wider) -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-[#2D3436] border-l-4 border-[#2D7A3A] pl-4 mb-8">
            Envoyez-nous un message
          </h2>
          <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">
            <input type="hidden" name="_subject" value="Nouveau message depuis adesz.fr" />

            <div>
              <label for="nom" class="block text-sm font-medium text-[#2D3436] mb-2">
                Nom <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                class="w-full rounded-lg border border-[#2D3436]/20 bg-white px-4 py-3 text-[#2D3436] placeholder-[#2D3436]/40 transition-colors focus:border-[#2D7A3A] focus:outline-none focus:ring-2 focus:ring-[#2D7A3A]/20"
                placeholder="Votre nom"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-[#2D3436] mb-2">
                Email <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-[#2D3436]/20 bg-white px-4 py-3 text-[#2D3436] placeholder-[#2D3436]/40 transition-colors focus:border-[#2D7A3A] focus:outline-none focus:ring-2 focus:ring-[#2D7A3A]/20"
                placeholder="votre@email.com"
              />
            </div>

            <div>
              <label for="sujet" class="block text-sm font-medium text-[#2D3436] mb-2">
                Sujet <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="sujet"
                name="sujet"
                required
                class="w-full rounded-lg border border-[#2D3436]/20 bg-white px-4 py-3 text-[#2D3436] placeholder-[#2D3436]/40 transition-colors focus:border-[#2D7A3A] focus:outline-none focus:ring-2 focus:ring-[#2D7A3A]/20"
                placeholder="L'objet de votre message"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-[#2D3436] mb-2">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full rounded-lg border border-[#2D3436]/20 bg-white px-4 py-3 text-[#2D3436] placeholder-[#2D3436]/40 transition-colors focus:border-[#2D7A3A] focus:outline-none focus:ring-2 focus:ring-[#2D7A3A]/20 resize-vertical"
                placeholder="Votre message..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-[#2D7A3A] px-8 py-3 text-sm font-semibold text-white shadow-md transition-all hover:bg-[#1B5E27] hover:shadow-lg"
            >
              <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
              </svg>
              Envoyer
            </button>
          </form>
        </div>

        <!-- Coordonnées (right) -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-[#2D3436] border-l-4 border-[#F5C518] pl-4 mb-8">
            Coordonn&eacute;es
          </h2>
          <div class="space-y-6">
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[#2D7A3A]/10">
                <svg class="h-5 w-5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[#2D3436]">Email</p>
                <a
                  href="mailto:adeszafaya@gmail.com"
                  class="mt-1 text-[#2D7A3A] hover:text-[#1B5E27] transition-colors"
                >
                  adeszafaya@gmail.com
                </a>
              </div>
            </div>

            <!-- Téléphone -->
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[#2D7A3A]/10">
                <svg class="h-5 w-5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[#2D3436]">T&eacute;l&eacute;phone</p>
                <a
                  href="tel:+33663046612"
                  class="mt-1 text-[#2D7A3A] hover:text-[#1B5E27] transition-colors"
                >
                  06 63 04 66 12
                </a>
              </div>
            </div>

            <!-- Adresse -->
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[#2D7A3A]/10">
                <svg class="h-5 w-5 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[#2D3436]">Adresse</p>
                <p class="mt-1 text-[#2D3436]/70">
                  491 Bd Pierre Delmas<br />
                  06600 Antibes
                </p>
              </div>
            </div>
          </div>

          <!-- Map placeholder or decorative element -->
          <div class="mt-10 rounded-xl bg-[#F8F7F4] border border-[#2D3436]/10 p-6 text-center">
            <div class="flex h-12 w-12 mx-auto items-center justify-center rounded-full bg-[#2D7A3A]/10 mb-3">
              <svg class="h-6 w-6 text-[#2D7A3A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
              </svg>
            </div>
            <p class="text-sm font-medium text-[#2D3436]">ADESZ</p>
            <p class="text-sm text-[#2D3436]/60 mt-1">
              Association loi 1901<br />
              bas&eacute;e &agrave; Antibes (06)
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
