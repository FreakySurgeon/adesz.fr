---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getPostsByCategory, CATEGORIES } from '../../lib/wordpress';
import { url } from '../../lib/utils';

const articles = await getPostsByCategory(CATEGORIES.PRESSE);
---

<BaseLayout title="Articles de presse - ADESZ" description="La revue de presse de l'ADESZ.">
  <PageHero
    title="Articles de presse"
    subtitle="La revue de presse de l'ADESZ."
    image="/images/Image4.jpg"
    imageAlt="Communauté de Zafaya"
    breadcrumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Articles de presse' },
    ]}
  />

  <!-- Articles -->
  {articles.length > 0 && (
    <section class="bg-white py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
          {articles.map((post) => {
            const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
            return (
              <ArticleCard
                title={post.title.rendered}
                date={post.date}
                excerpt={post.excerpt.rendered}
                slug={post.slug}
                image={featuredImage}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Empty state -->
  {articles.length === 0 && (
    <section class="bg-white py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-lg text-[#2D3436]/70">Aucun article de presse disponible pour le moment.</p>
      </div>
    </section>
  )}
</BaseLayout>
