---
import { url } from '../lib/utils';

const quickLinks = [
  { label: 'Accueil', href: url('/') },
  { label: 'Nos projets', href: url('/projets') },
  { label: 'Nos r\u00e9alisations', href: url('/realisations') },
  { label: 'Articles de presse', href: url('/presse') },
  { label: 'Adh\u00e9rer', href: url('/adherer') },
  { label: 'Contact', href: url('/contact') },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-green-gradient text-white overflow-hidden">
  <!-- Decorative pattern -->
  <div class="absolute inset-0 pattern-diamonds opacity-30"></div>
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#F5C518] via-[#2D7A3A] to-[#F5C518]"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
      <!-- About Column -->
      <div>
        <div class="mb-6 inline-block rounded-xl bg-white p-2 shadow-lg shadow-black/10">
          <img
            src={url('/images/logo-adesz-2026.jpg')}
            alt="ADESZ"
            class="h-16 w-auto rounded-lg"
          />
        </div>
        <p class="text-base leading-relaxed text-white/80">
          Association pour le D&eacute;veloppement &Eacute;conomique et Social de Zafaya
        </p>
        <p class="mt-4 text-sm text-white/50">
          491 Bd Pierre Delmas, 06600 Antibes
        </p>
        <div class="mt-6 h-1 w-12 rounded-full bg-gradient-to-r from-[#F5C518] to-[#F5C518]/0"></div>
      </div>

      <!-- Navigation Column -->
      <div>
        <h3 class="font-display mb-6 text-lg text-white/90">
          Liens rapides
        </h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="group flex items-center gap-2 text-sm text-white/60 transition-all hover:text-[#F5C518] hover:translate-x-1"
              >
                <span class="h-px w-3 bg-white/20 transition-all group-hover:w-5 group-hover:bg-[#F5C518]"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-display mb-6 text-lg text-white/90">
          Contact
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#F5C518]/10">
              <svg class="h-4 w-4 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <a href="mailto:adeszafaya@gmail.com" class="text-sm text-white/60 transition-colors hover:text-[#F5C518]">
              adeszafaya@gmail.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[#F5C518]/10">
              <svg class="h-4 w-4 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <a href="tel:+33663046612" class="text-sm text-white/60 transition-colors hover:text-[#F5C518]">
              06 63 04 66 12
            </a>
          </li>
        </ul>

        <!-- Social Links -->
        <div class="mt-8 flex gap-3">
          <a
            href="https://facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-white/60 backdrop-blur-sm transition-all duration-300 hover:bg-[#F5C518] hover:text-[#2D3436] hover:-translate-y-1 hover:shadow-lg hover:shadow-[#F5C518]/20"
            aria-label="Facebook"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
            </svg>
          </a>
          <a
            href="https://youtube.com"
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 text-white/60 backdrop-blur-sm transition-all duration-300 hover:bg-[#F5C518] hover:text-[#2D3436] hover:-translate-y-1 hover:shadow-lg hover:shadow-[#F5C518]/20"
            aria-label="YouTube"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23 9.71a8.5 8.5 0 00-.91-4.13 2.92 2.92 0 00-1.72-1A78.36 78.36 0 0012 4.27a78.45 78.45 0 00-8.34.3 2.87 2.87 0 00-1.46.74c-.9.83-1 2.25-1.1 3.45a48.29 48.29 0 000 6.48 9.55 9.55 0 00.3 2 3.14 3.14 0 00.71 1.36 2.86 2.86 0 001.49.78A45.18 45.18 0 0012 19.73a45.18 45.18 0 008.35-.37 2.86 2.86 0 001.49-.78 2.93 2.93 0 00.71-1.36 9.55 9.55 0 00.3-2 48.29 48.29 0 00.15-5.51zM9.74 14.85V8.66l5.92 3.11c-1.66.88-3.97 2.1-5.92 3.08z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="relative z-10 border-t border-white/10">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-2 px-4 py-5 sm:flex-row sm:px-6 lg:px-8">
      <p class="text-xs text-white/40">
        &copy; {currentYear} ADESZ &mdash; Tous droits r&eacute;serv&eacute;s
      </p>
      <p class="text-xs text-white/40">
        R&eacute;alisation T. Chauvet
      </p>
    </div>
  </div>
</footer>
