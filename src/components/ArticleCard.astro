---
import { url } from '../lib/utils';

interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  image?: string;
  basePath?: string;
}

const { title, date, excerpt, slug, image, basePath = '/presse' } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

import { decodeHtmlEntities } from '../lib/wordpress';
const cleanExcerpt = decodeHtmlEntities(excerpt.replace(/<[^>]*>/g, '')).slice(0, 150).trim() + '...';
---

<article class="reveal group relative overflow-hidden rounded-2xl bg-white shadow-md transition-all duration-500 hover:shadow-xl hover:-translate-y-1">
  <div class="relative aspect-[16/10] overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-green-gradient pattern-diamonds">
        <svg class="h-12 w-12 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6V7.5z" />
        </svg>
      </div>
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[#0F3D18]/40 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
  </div>

  <div class="p-7">
    <time datetime={date} class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-[#2D7A3A]">
      <span class="h-1 w-1 rounded-full bg-[#2D7A3A]"></span>
      {formattedDate}
    </time>
    <h3 class="mt-3 font-display text-lg leading-snug text-[#2D3436] sm:text-xl">
      <Fragment set:html={title} />
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-[#2D3436]/60">
      {cleanExcerpt}
    </p>
    <a
      href={url(`${basePath}/${slug}`)}
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[#2D7A3A] transition-all duration-300 hover:gap-3"
    >
      Lire la suite
      <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</article>
