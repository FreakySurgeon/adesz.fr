---
interface Props {
  title: string;
  date: string;
  excerpt: string;
  slug: string;
  image?: string;
}

const { title, date, excerpt, slug, image } = Astro.props;

// Format date in French
const formattedDate = new Date(date).toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

// Strip HTML tags from excerpt and truncate
const cleanExcerpt = excerpt.replace(/<[^>]*>/g, '').slice(0, 150).trim() + '...';
---

<article class="overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg">
  <div class="aspect-[16/10] overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-[#2D7A3A] to-[#1B5E27]">
        <svg class="h-12 w-12 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6V7.5z" />
        </svg>
      </div>
    )}
  </div>
  <div class="p-6">
    <time datetime={date} class="text-xs font-medium text-[#2D7A3A]">
      {formattedDate}
    </time>
    <h3 class="mt-2 text-lg font-semibold leading-snug text-[#2D3436]">
      <Fragment set:html={title} />
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-[#2D3436]/70">
      {cleanExcerpt}
    </p>
    <a
      href={`/presse/${slug}`}
      class="mt-4 inline-flex items-center text-sm font-medium text-[#2D7A3A] transition-colors hover:text-[#1B5E27]"
    >
      Lire la suite
      <span class="ml-1">&rarr;</span>
    </a>
  </div>
</article>
