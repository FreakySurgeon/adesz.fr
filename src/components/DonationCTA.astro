---
import { url } from '../lib/utils';
---

<section class="relative overflow-hidden py-20 sm:py-24 grain-overlay">
  <!-- Background with warm gradient + pattern -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#F5C518]/10 via-[#F8F7F4] to-[#2D7A3A]/5"></div>
  <div class="absolute inset-0 pattern-diamonds"></div>

  <!-- Decorative elements -->
  <div class="absolute -top-16 -right-16 h-48 w-48 rounded-full bg-[#F5C518]/10 blur-3xl"></div>
  <div class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full bg-[#2D7A3A]/10 blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <!-- Label -->
    <div class="reveal mb-6 flex items-center justify-center gap-3">
      <span class="h-px w-8 bg-[#F5C518]"></span>
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-[#2D7A3A]">Agir ensemble</span>
      <span class="h-px w-8 bg-[#F5C518]"></span>
    </div>

    <h2 class="reveal font-display text-3xl text-[#2D3436] sm:text-4xl lg:text-5xl">
      Soutenez nos actions
    </h2>

    <p class="reveal reveal-delay-1 mx-auto mt-5 max-w-xl text-base leading-relaxed text-[#2D3436]/60 sm:text-lg">
      Votre don est d&eacute;ductible &agrave; <strong class="text-[#2D7A3A]">66%</strong> de votre imp&ocirc;t sur le revenu
      ou <strong class="text-[#2D7A3A]">60%</strong> de l'imp&ocirc;t sur les soci&eacute;t&eacute;s.
    </p>

    <div class="reveal reveal-delay-2 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={url('/adherer')}
        class="group inline-flex items-center gap-2 rounded-full bg-[#F5C518] px-8 py-3.5 text-base font-bold text-[#2D3436] shadow-lg shadow-[#F5C518]/20 transition-all duration-300 hover:bg-[#e0b315] hover:shadow-xl hover:shadow-[#F5C518]/30 hover:-translate-y-0.5"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        Faire un don
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a
        href={url('/adherer')}
        class="inline-flex items-center gap-2 rounded-full bg-[#2D7A3A] px-8 py-3.5 text-base font-bold text-white shadow-lg shadow-[#2D7A3A]/20 transition-all duration-300 hover:bg-[#1B5E27] hover:shadow-xl hover:shadow-[#2D7A3A]/30 hover:-translate-y-0.5"
      >
        Adh&eacute;rer pour 15&euro;
      </a>
    </div>
  </div>
</section>
