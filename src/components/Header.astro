---
const navItems = [
  {
    label: 'Presentation',
    children: [
      { label: 'Le Pays', href: '/presentation/pays' },
      { label: 'Le Village', href: '/presentation/village' },
      { label: "L'Association", href: '/presentation/association' },
    ],
  },
  {
    label: "Domaines d'action",
    children: [
      { label: 'Sante', href: '/domaines#sante' },
      { label: 'Education', href: '/domaines#education' },
      { label: 'Agriculture', href: '/domaines#agriculture' },
      { label: 'Developpement', href: '/domaines#developpement' },
      { label: 'Urgences', href: '/domaines#urgences' },
    ],
  },
  {
    label: 'Projets',
    children: [
      { label: 'Projets en cours', href: '/projets' },
      { label: 'Projets a venir', href: '/projets' },
    ],
  },
  { label: 'Nos realisations', href: '/realisations' },
  { label: 'Nos partenaires', href: '/partenaires' },
  { label: 'Articles de presse', href: '/presse' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="/images/logo.png"
          alt="ADESZ - Retour a l'accueil"
          class="h-10 w-auto lg:h-14"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex lg:items-center lg:gap-1" aria-label="Navigation principale">
        {navItems.map((item) =>
          item.children ? (
            <div class="group relative">
              <button
                type="button"
                class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium text-[#2D3436] transition-colors hover:bg-[#2D7A3A]/10 hover:text-[#2D7A3A]"
              >
                {item.label}
                <svg class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full z-50 min-w-48 rounded-xl bg-white py-2 opacity-0 shadow-lg ring-1 ring-black/5 transition-all duration-200 group-hover:visible group-hover:opacity-100">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2 text-sm text-[#2D3436] transition-colors hover:bg-[#2D7A3A]/10 hover:text-[#2D7A3A]"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="rounded-lg px-3 py-2 text-sm font-medium text-[#2D3436] transition-colors hover:bg-[#2D7A3A]/10 hover:text-[#2D7A3A]"
            >
              {item.label}
            </a>
          )
        )}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href="/adherer"
          class="hidden rounded-full bg-[#F5C518] px-5 py-2 text-sm font-semibold text-[#2D3436] transition-colors hover:bg-[#e0b315] sm:inline-block"
        >
          Faire un don
        </a>

        <!-- Mobile Hamburger -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center rounded-lg p-2 text-[#2D3436] transition-colors hover:bg-gray-100 lg:hidden"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 top-16 z-40 hidden bg-white lg:hidden">
    <nav class="h-full overflow-y-auto px-4 pb-6 pt-4" aria-label="Navigation mobile">
      {navItems.map((item) =>
        item.children ? (
          <details class="group/mobile border-b border-gray-100">
            <summary class="flex cursor-pointer items-center justify-between py-3 text-base font-medium text-[#2D3436] marker:content-[''] [&::-webkit-details-marker]:hidden">
              {item.label}
              <svg class="h-5 w-5 shrink-0 transition-transform group-open/mobile:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="pb-3 pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block rounded-lg py-2 pl-3 text-sm text-[#2D3436]/80 transition-colors hover:text-[#2D7A3A]"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={item.href}
            class="block border-b border-gray-100 py-3 text-base font-medium text-[#2D3436] transition-colors hover:text-[#2D7A3A]"
          >
            {item.label}
          </a>
        )
      )}

      <!-- Mobile CTA -->
      <div class="mt-6">
        <a
          href="/adherer"
          class="block w-full rounded-full bg-[#F5C518] py-3 text-center text-base font-semibold text-[#2D3436] transition-colors hover:bg-[#e0b315]"
        >
          Faire un don
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  if (menuBtn && mobileMenu && hamburgerIcon && closeIcon) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));

      // Prevent body scroll when menu is open
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    // Close menu when clicking a link
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }
</script>
