---
import { url } from '../lib/utils';

const navItems = [
  {
    label: 'Pr\u00e9sentation',
    children: [
      { label: 'Le Pays', href: url('/presentation/pays') },
      { label: 'Le Village', href: url('/presentation/village') },
      { label: "L'Association", href: url('/presentation/association') },
    ],
  },
  {
    label: "Domaines d'action",
    children: [
      { label: 'Sant\u00e9', href: url('/domaines#sante') },
      { label: '\u00c9ducation', href: url('/domaines#education') },
      { label: 'Agriculture', href: url('/domaines#agriculture') },
      { label: 'D\u00e9veloppement', href: url('/domaines#developpement') },
      { label: 'Urgences', href: url('/domaines#urgences') },
    ],
  },
  {
    label: 'Projets',
    children: [
      { label: 'Projets en cours', href: url('/projets') },
      { label: 'Projets \u00e0 venir', href: url('/projets') },
    ],
  },
  { label: 'R\u00e9alisations', href: url('/realisations') },
  { label: 'Partenaires', href: url('/partenaires') },
  { label: 'Presse', href: url('/presse') },
];
---

<header class="sticky top-0 z-50 border-b border-[#2D3436]/5 bg-white/90 backdrop-blur-lg transition-shadow duration-300" id="site-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between lg:h-20">
      <!-- Logo -->
      <a href={url('/')} class="flex-shrink-0 transition-opacity hover:opacity-80">
        <img
          src={url('/images/logo-adesz-2026.jpg')}
          alt="ADESZ - Retour \u00e0 l'accueil"
          class="h-12 w-auto lg:h-16 rounded-sm"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex lg:items-center lg:gap-0.5" aria-label="Navigation principale">
        {navItems.map((item) =>
          item.children ? (
            <div class="group relative">
              <button
                type="button"
                class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-semibold text-[#2D3436]/80 transition-colors hover:text-[#2D7A3A]"
              >
                {item.label}
                <svg class="h-3.5 w-3.5 opacity-50 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="invisible absolute left-0 top-full z-50 min-w-52 translate-y-1 rounded-xl border border-[#2D3436]/5 bg-white py-2 opacity-0 shadow-xl shadow-[#2D3436]/5 transition-all duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="flex items-center gap-2 px-4 py-2.5 text-sm text-[#2D3436]/70 transition-all hover:bg-[#2D7A3A]/5 hover:text-[#2D7A3A] hover:pl-5"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="rounded-lg px-3 py-2 text-sm font-semibold text-[#2D3436]/80 transition-colors hover:text-[#2D7A3A]"
            >
              {item.label}
            </a>
          )
        )}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href={url('/adherer')}
          class="hidden rounded-full bg-[#F5C518] px-6 py-2.5 text-sm font-bold text-[#2D3436] shadow-sm shadow-[#F5C518]/20 transition-all duration-300 hover:bg-[#e0b315] hover:shadow-md hover:shadow-[#F5C518]/30 hover:-translate-y-px sm:inline-flex sm:items-center sm:gap-1.5"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          Faire un don
        </a>

        <!-- Mobile Hamburger -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center rounded-lg p-2 text-[#2D3436] transition-colors hover:bg-[#2D7A3A]/5 lg:hidden"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
        >
          <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 top-16 z-40 hidden bg-white/95 backdrop-blur-lg lg:hidden">
    <nav class="h-full overflow-y-auto px-6 pb-6 pt-6" aria-label="Navigation mobile">
      {navItems.map((item) =>
        item.children ? (
          <details class="group/mobile border-b border-[#2D3436]/5">
            <summary class="flex cursor-pointer items-center justify-between py-4 text-base font-semibold text-[#2D3436] marker:content-[''] [&::-webkit-details-marker]:hidden">
              {item.label}
              <svg class="h-5 w-5 shrink-0 text-[#2D3436]/40 transition-transform duration-200 group-open/mobile:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="pb-4 pl-4">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="flex items-center gap-2 rounded-lg py-2.5 pl-3 text-sm text-[#2D3436]/70 transition-colors hover:text-[#2D7A3A]"
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-[#2D7A3A]/30"></span>
                  {child.label}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={item.href}
            class="block border-b border-[#2D3436]/5 py-4 text-base font-semibold text-[#2D3436] transition-colors hover:text-[#2D7A3A]"
          >
            {item.label}
          </a>
        )
      )}

      <!-- Mobile CTA -->
      <div class="mt-8">
        <a
          href={url('/adherer')}
          class="flex w-full items-center justify-center gap-2 rounded-full bg-[#F5C518] py-3.5 text-base font-bold text-[#2D3436] shadow-lg shadow-[#F5C518]/20 transition-colors hover:bg-[#e0b315]"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          Faire un don
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const header = document.getElementById('site-header');

  if (menuBtn && mobileMenu && hamburgerIcon && closeIcon) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      hamburgerIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        hamburgerIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }

  if (header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) {
        header.classList.add('shadow-md');
      } else {
        header.classList.remove('shadow-md');
      }
    }, { passive: true });
  }
</script>
