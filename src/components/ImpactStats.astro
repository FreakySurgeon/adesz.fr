---

<section class="relative bg-green-gradient py-20 sm:py-24 grain-overlay overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 pattern-diamonds opacity-50"></div>
  <div class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-[#F5C518]/5 blur-3xl"></div>
  <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-white/5 blur-3xl"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat, i) => (
        <div class={`reveal reveal-delay-${i + 1} group text-center`}>
          <!-- Icon -->
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/10 backdrop-blur-sm transition-all duration-300 group-hover:bg-[#F5C518]/20 group-hover:scale-110">
            <svg class="h-6 w-6 text-[#F5C518]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
            </svg>
          </div>
          <!-- Value -->
          <p class="font-display text-5xl text-white sm:text-6xl">
            {stat.value}
          </p>
          <!-- Accent bar -->
          <div class="mx-auto mt-3 h-1 w-8 rounded-full bg-[#F5C518]/40 transition-all duration-300 group-hover:w-12 group-hover:bg-[#F5C518]"></div>
          <!-- Label -->
          <p class="mt-3 text-base font-medium text-white/80 sm:text-lg">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
