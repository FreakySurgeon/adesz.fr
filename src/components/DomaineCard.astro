---
interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
}

const { title, description, image, link } = Astro.props;
---

<article class="overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg">
  <div class="aspect-[16/10] overflow-hidden">
    <img
      src={image}
      alt={title}
      class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h3 class="text-xl font-semibold text-[#2D3436]">{title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-[#2D3436]/70">{description}</p>
    <a
      href={link}
      class="mt-4 inline-flex items-center text-sm font-medium text-[#2D7A3A] transition-colors hover:text-[#1B5E27]"
    >
      En savoir plus
      <span class="ml-1">&rarr;</span>
    </a>
  </div>
</article>
